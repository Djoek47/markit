# Same Supabase project as Circe et Venus (Markit needs auth + subscription reads).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Creatix production URL (AI proxy + Ariadne embed target).
NEXT_PUBLIC_CREATIX_APP_URL=https://www.circeetvenus.com

# Set on Creatix to the Markit origin (no trailing slash) so /api/ai/divine-manager-realtime allows CORS (optional if you only use Markit API proxies).
# Creatix: NEXT_PUBLIC_MARKIT_URL=https://markit.example.com

# Incident-only: re-enable keyword voice-edit row + Space. Default off (use Realtime “Start live voice”).
# NEXT_PUBLIC_MARKIT_DIVINE_KEYWORD_INCIDENT=true

# This Markit deployment URL (no trailing slash) — used for metadata/OG. Example: http://localhost:3020
NEXT_PUBLIC_MARKIT_APP_URL=
NEXT_PUBLIC_FRAMER_TRACED_EXPORT_ENABLED=false
ARIADNE_V2_EMBED_ENABLED=false
ARIADNE_V2_DETECT_ENABLED=false
ARIADNE_CONFIDENCE_GATING_ENABLED=false
MARKIT_ARIADNE_SHARED_SECRET=

# Supabase `profiles.id` of the creator — required for Creatix M2M Ariadne (x-creatix-actor-user-id).
CREATIX_ACTOR_USER_ID=

# Same value as Creatix FRAME_EXPORT_SECRET (server-only).
FRAME_EXPORT_SECRET=

# Optional: extra hosts allowed in exportUrl (merged with circeetvenus.com defaults).
# CREATIX_EXPORT_HOST_ALLOWLIST=my-preview.vercel.app

# Vercel Blob (optional) — for future server render / artifact upload on POST /api/render.
# BLOB_READ_WRITE_TOKEN=

# Same value on Creatix — enables POST /api/creatix/divine-test-enqueue (SSE smoke test).
# DIVINE_TEST_ENQUEUE_SECRET=
